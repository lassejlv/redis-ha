REDIS_VERSION=7.4
REDIS_PASSWORD=
CLUSTER_NODE_TIMEOUT=5000
REDIS_MAXMEMORY=

# HAProxy load balancer ports
HAPROXY_WRITE_PORT=6380
HAPROXY_READ_PORT=6381
HAPROXY_STATS_PORT=8404

# Multi-server (optional, leave empty for single-server)
MULTI_SERVER=false
ANNOUNCE_IP=

# Monitoring
MONITOR_ENABLED=false
MONITOR_INTERVAL=10
MONITOR_MEMORY_THRESHOLD=80

# Email (SMTP)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_TLS=true

# Discord
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# Generic webhook
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_HEADERS=
